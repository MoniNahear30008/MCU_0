__constant int SPLIT_CHAIN          = 0;    // 1: Split Chain  (BRCM_TAP+CoreSight_DAP)
                                            // 0: Single Chain (BRCM_TAP+CoreSight_DAP+Q8_0+Q8_1+Q8_2+Q8_3)

