/*********************************************************************
*
*       Global Variables
*
**********************************************************************
*/
U32 A55_DBG_REG_BASE_ADDR;


/*********************************************************************
*
*       _WaitWhileBusy
*
*  Function descripton
*    Wait until read value is not busy.
*
*  Return value
*      0 O.K.
*    < 0 Error
*     -1 Timeout reached
*     -2 Error reading/writing DAP
*/
static int _WaitWhileBusy(U32 Addr, U32 Mask, U32 RefValue, U32 Timeout) {
  int r;
  int t;
  U32 Status;

  RefValue &= Mask;
  r         = -1;
  //
  // Wait for operation to complete
  //
  t = JLINK_GetTime() + Timeout;
  do {
    r  = JLINK_MEM_ReadU32(Addr);
    //
    // Check for error while reading/writing AP.
    // We do this because this function might be called after a reset,
    // e.g. from _WaitCPUHalted()
    //
    if (r == -1) {                      // Connection lost ? => Error.
      r = -2;
      break;
    }
    Status = r;
    if ((Status & Mask) == RefValue) { // Operation complete? => Done.
      r = 0;
      break;
    }
    if ((t - JLINK_GetTime()) < 0) {    // Timeout reached? => Error.
      r = -1;
      break;
    }
  } while (1);
  return r;
}


/*********************************************************************
*
*       _WaitCPUHalted
*
*  Function description
*    Wait for DHCSR to signal that the CPU is halted.
*
*  Return value
*      0 O.K.
*    < 0 Error
*/
static int _WaitCPUHalted(void) {
  int r;

  r = _WaitWhileBusy(_DHCSR_ADDR, _BIT_S_HALTED, _BIT_S_HALTED, _DEF_BUSY_TIMEOUT);
  if (r == -1) {
    JLINK_SYS_Report("  Timeout while waiting for CPU to halt.");
  } else if (r == -2) {
    JLINK_SYS_Report("  Error while checking CPU state.");
  }
  return r;
}


/*********************************************************************
*
*       _M7_Reset
*
*  Function description
*    Reset and wait until CPU is halted.
*
*  Return value
*      0  O.K.
*    < 0  Error
*/
static int _M7_Reset(void) {
  int r;
  U32 v;
  U32 demcr;

  r = JLINK_MEM_ReadU32(_DHCSR_ADDR);
  Report1("DHCSR= ", r);
  if (r < 0) {
    return -1;
  }
  v = r;
  v &= 0x3F;                                         // Mask out "debug" bits
  v |= (0xA05F << 16);                               // Debug key to make a write to the DHCSR a valid one
  v |= (1 << 1);                                     // Halt the core
  v |= (1 << 0);                                     // Enable debug functionalities of the core
  JLINK_MEM_WriteU32(_DHCSR_ADDR, v);

  Report1("DHCSRv= ", v);
  r = JLINK_MEM_ReadU32(_DHCSR_ADDR);
  Report1("DHCSR= ", r);

  demcr = JLINK_MEM_ReadU32(_DEMCR_ADDR);
  JLINK_MEM_WriteU32(_DEMCR_ADDR, demcr | (1 << 0)); // Set VC_CORERESET
  JLINK_MEM_WriteU32(_AIRCR_ADDR, 0x05FA0004);       // SYSRESETREQ
  r = _WaitCPUHalted();
  if (r < 0) {
    return -1;
  }
  //_InitDAP();
  return 0;
}

/*********************************************************************
*
*       _DisableWDT
*
*  Function description
*    Disable Watchdog Timer
*
*/
static void _DisableWDT(void) {

  int v;
  int wdt;

   Report("Disabling WatchDog Timer");

  //
  // Halt WDT
  //
  // Watchdog NMI Mask
  v   = JLINK_MEM_WriteU32(0xE0240300, 0x0); 
  
  // Disable Watchdog
  v   = JLINK_MEM_WriteU32(0xE0250c00, 0x1ACCE551);
  v   = JLINK_MEM_WriteU32(0xE0250008, 0x0);
  v   = JLINK_MEM_WriteU32(0xE0250c00, 0x0);
  wdt = JLINK_MEM_ReadU32(0xE0250008);
  Report1("WDGT0 = ", wdt);
  
  if (wdt == 0x0) {
    return(0);
  }
  else {
    return(1);
  }
}

/*********************************************************************
*
*       _Read_M7_MCU_ID
*
*  Function description
*    Read mcu_id
*
*/
static int _Read_M7_MCU_ID(int exp_MCU_ID) {

  int id;
   
  id  = JLINK_MEM_ReadU32(MCU_CLUSTER_ID_Adr);
  Report1("MCU_CLUSTER_ID = ", id);

  id &= 0xFF;
  
  if (id != exp_MCU_ID) {
    Report1("MCU_CLUSTER_ID mismatch! Exp = ", exp_MCU_ID);
  }
  
  return (id);
}

/*********************************************************************
*
*       _ReleaseReset_MCU_Utility
*
*  Function description
*    Read mcu_id
*
*/
static void _Enable_MCU_Utility(int enable) {

  U32 mcu_u_initvtor;
  U32 mcu_misc_ctl;
  U32 RIG_CLKNRST_cpu_dma_sys_reset_control;
  int v;

  if (MCU_U_TRAPCODE_ADDR != 0xFFFFFFFF) {

    mcu_u_initvtor = MCU_U_TRAPCODE_ADDR;

    //------------------------------
    // Add Code to Trap MCU Utility
    //------------------------------
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x00, 0x20008000);          /*     Initial Stack Pointer */
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x04, mcu_u_initvtor+0x1D); /*     Reset Handler */
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x08, mcu_u_initvtor+0x1D); /* -14 NMI Handler */
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x0C, mcu_u_initvtor+0x1D); /* -13 Hard Fault Handler */
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x10, mcu_u_initvtor+0x1D); /* -12 MPU Fault Handler */
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x14, mcu_u_initvtor+0x1D); /* -11 Bus Fault Handler */
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x18, mcu_u_initvtor+0x1D); /* -10 Usage Fault Handler */
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x1C, 0xe7fee7fe);          /* while(1); */
    v   = JLINK_MEM_WriteU32(mcu_u_initvtor+0x20, 0xe7fee7fe);          /* while(1); */
  
    //------------------------------
    // Initiliaze INITVTOR
    //------------------------------
    JLINK_MEM_WriteU32(MCU_U_INITVTOR_Adr, mcu_u_initvtor);
    mcu_u_initvtor  = JLINK_MEM_ReadU32(MCU_U_INITVTOR_Adr);
    Report1("MCU_U_INITVTOR = ", mcu_u_initvtor);
  }

  //------------------------------
  // Enable mcu_utility
  //------------------------------
  mcu_misc_ctl  = JLINK_MEM_ReadU32(MCU_MISC_CTL_Adr);
  //Report1("MCU_MISC_CTL = ", mcu_misc_ctl);
  
  if (enable) {
    mcu_misc_ctl |= (1<<29);                // u_mcu_en=1
    mcu_misc_ctl &= ((0xFFFFFFFF)^(1<<28)); // u_mcu_wait=0
  }
  else {
    mcu_misc_ctl &= ((0xFFFFFFFF)^(1<<29)); // u_mcu_en=0
    mcu_misc_ctl |= (1<<28);                // u_mcu_wait=1
  }

  JLINK_MEM_WriteU32(MCU_MISC_CTL_Adr, mcu_misc_ctl);
  //mcu_misc_ctl  = JLINK_MEM_ReadU32(MCU_MISC_CTL_Adr);
  //Report1("MCU_MISC_CTL = ", mcu_misc_ctl);

  //------------------------------
  // Release Reset
  //------------------------------
  RIG_CLKNRST_cpu_dma_sys_reset_control  = JLINK_MEM_ReadU32(RIG_CLKNRST_cpu_dma_sys_reset_control_Adr);
  // Report1("RIG_CLKNRST_cpu_dma_sys_reset_control = ", RIG_CLKNRST_cpu_dma_sys_reset_control);

  // cpu_dma_sys_mcu1_rstb_frcval [04]
  // cpu_dma_sys_mcu1_rstb_frc    [05]
  //RIG_CLKNRST_cpu_dma_sys_reset_control |= (1<<4);              // cpu_dma_sys_mcu1_rstb_frcval=1
  RIG_CLKNRST_cpu_dma_sys_reset_control &= ((0xFFFFFFFF)^(1<<5)); // cpu_dma_sys_mcu1_rstb_frc=0

  JLINK_MEM_WriteU32(RIG_CLKNRST_cpu_dma_sys_reset_control_Adr, RIG_CLKNRST_cpu_dma_sys_reset_control);
  //RIG_CLKNRST_cpu_dma_sys_reset_control  = JLINK_MEM_ReadU32(RIG_CLKNRST_cpu_dma_sys_reset_control_Adr);
  //Report1("RIG_CLKNRST_cpu_dma_sys_reset_control = ", RIG_CLKNRST_cpu_dma_sys_reset_control);

}


/*********************************************************************
*
*       _A55_DBG_Reg_Access
*            int op           0: read, 1: write
*            u32 reg_addr
*            u32 val
*
*  Function description
*    Read/Write A55 Memory-Mapped Debug Register
*
*       ARM® Cortex®-A55 Core Technical Reference Manual
*         D3.1 Memory-mapped debug register summary
*
*        Arm® Architecture Reference Manual for A-profile architecture
*           H8.6 External debug interface registers
*
*/
static U32 _A55_DBG_Reg_Access(int op, U32 reg_addr, U32 val) {
    
    U32 ret_val;
    U32 Ctrl;

    //
    // Select APB-AP and prepare control register
    //
    // AP Select register, SELECT
    // https://developer.arm.com/documentation/100536/0302/About-the-programmers-model/DAP-registers/JTAG-DP-registers/AP-Select-register--SELECT?lang=en
    JLINK_CORESIGHT_WriteDP(JLINK_CORESIGHT_DP_REG_SELECT, (2 << 24) | (0 << 4));  // Select AP[2], bank 0


    // APB-AP Control/Status Word register, CSW, 0x00
    // https://developer.arm.com/documentation/100536/0302/About-the-programmers-model/DAP-registers/APB-AP-registers/APB-AP-Control-Status-Word-register--CSW--0x00?lang=en
    Ctrl =  0
         | (2 << 0)    // AP-access size. Fixed to 2: 32-bit
         | (1 << 4)    // Auto increment TAR after read/write access. Increment is NOT performed on access to banked data registers 0-3.
         | (1 << 31)   // Enable software access to the Debug APB bus.
        ;
    JLINK_CORESIGHT_WriteAP(JLINK_CORESIGHT_AP_REG_CTRL, Ctrl);

    //
    // Perform some other init steps which are required to get full control of the debug logic
    //
    
    // APB-AP Transfer Address Register, TAR, 0x04
    // https://developer.arm.com/documentation/100536/0302/About-the-programmers-model/DAP-registers/APB-AP-registers/APB-AP-Transfer-Address-Register--TAR--0x04?lang=en
    JLINK_CORESIGHT_WriteAP(JLINK_CORESIGHT_AP_REG_ADDR, reg_addr);

    // APB-AP Data Read/Write register, DRW, 0x0C
    // https://developer.arm.com/documentation/100536/0302/About-the-programmers-model/DAP-registers/APB-AP-registers/APB-AP-Data-Read-Write-register--DRW--0x0C?lang=en
    if (op == 0) {
      ret_val = JLINK_CORESIGHT_ReadAP(JLINK_CORESIGHT_AP_REG_DATA);
    }
    else {
      JLINK_CORESIGHT_WriteAP(JLINK_CORESIGHT_AP_REG_DATA, val);
      ret_val = val;
    }

    return(ret_val);
}

/*********************************************************************
*
*       _Read_A55_CORE_ID
*
*  Function description
*    Read mcu_id
*
*/
static int _Read_A55_CORE_ID(int exp_CORE_ID) {

  U32 id;
   
  // Read EDDEVAFF0
  id  = _A55_DBG_Reg_Access(0, A55_DBG_REG_BASE_ADDR + A55_EDDEVAFF0_offset, 0);
  //Report1("EDDEVAFF0 = ", id);

  id = (id>>8)&0xFF;
  Report1("A55_CORE_ID = ", id);
  
  if (id != exp_CORE_ID) {
    Report1("A55_CORE_ID mismatch! Exp = ", exp_CORE_ID);
  }
  
  return (id);
}

