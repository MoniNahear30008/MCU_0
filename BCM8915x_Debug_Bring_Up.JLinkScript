/*********************************************************************
*
*       InitTarget
*/
void InitTarget(void) {
  
  int v;
  int Ctrl;
  int BitPos;
  
  if (PROGRAM_BRCM_TAP == 1) {
    //
    // By performing a TRST reset, we make sure that only the BRCM TAP module is in the scan chain
    //
    JTAG_TRSTPin = 0;
    SYS_Sleep(50);
    JTAG_TRSTPin = 1;
    SYS_Sleep(50);
    JTAG_Write(0x1F, 0, 6); // int JLINK_JTAG_Write(U32 tms, U32 tdi, U32 NumBits);
    
    //
    // Setup JTAG config to "talk" to the BRCM TAP, so we can use the JTAG API functions
    //
    JTAG_Reset();                // Perform TAP reset and J-Link JTAG auto-detection
    Report1("JTAG_TotalIRLen = ",  JTAG_TotalIRLen);
    if (JTAG_TotalIRLen != 8) {
      MessageBox("Could not find BCM8915x board (Total IRLen mismatch)");
      return 1;
    }
    
    // JTAG_DRPre  = 0;
    // JTAG_DRPost = 0;
    // JTAG_IRPre  = 0;
    // JTAG_IRPost = 0;
    // JTAG_IRLen  = 8;
    
    //
    // Check IDCODE of BRCM-TAP
    //
    JTAG_WriteIR(0xF4);   // IDCODE instruction for BRCM device
    BitPos = JTAG_WriteDR(0x00000000, 32);
    v = JTAG_GetU32(BitPos);
    Report1("BRCM IDCODE:",  v);
    if ((v & BRCM_TAP_ID_MASK) != (BRCM_TAP_ID & BRCM_TAP_ID_MASK)) {
      MessageBox("Unexpected BRCM IDCODE");
      return 1;
    }

    if (SPLIT_CHAIN == 1) {
      // Program BRCM TAP to change JTAG Mode to Split scan chain.
      //       IRCODE=8’bxxxx0011
      //       DRCODE=10’b00_0001_0001
      JTAG_WriteIR(0xF3);           // IRCODE=8’bxxxx0011
      JTAG_WriteDR(0x00000011, 10); // DRCODE=10’b00_0001_0001
    }
    else if (SPLIT_CHAIN == 0) {
      // Program BRCM TAP to change JTAG Mode to Single scan chain.
      //       IRCODE=8’bxxxx0011
      //       DRCODE=10'b00_0001_0000 (when secure_boot =0)
      //       DRCODE=10'b00_0001_0100 (when secure_boot =1)
      JTAG_WriteIR(0xF3);             // IRCODE=8’bxxxx0011
      if (SECURE_BOOT == 0) {
        JTAG_WriteDR(0x00000010, 10); // DRCODE=10'b00_0001_0000 (when secure_boot =0)
      }
      else {
        JTAG_WriteDR(0x00000014, 10); // DRCODE=10'b00_0001_0100 (when secure_boot =1)
      }
    }

  } // if (PROGRAM_BRCM_TAP == 1)
  
  // Now BRCM TAP and DAP TAP are in the scan chain. IRwidth=8+4=
  //
  // Setup JTAG config to "talk" to the BRCM TAP, so we can use the JTAG API functions
  //
  if (SPLIT_CHAIN == 1) {
    Report("Manually configuring JTAG chain for Split Chain");
    JTAG_SetDeviceId(0, CoreSight_DAP_ID);  // IRLen: 4 => CoreSight DAP   (closer to TDO)
    JTAG_SetDeviceId(1, BRCM_TAP_ID);       // IRLen: 8 => BRCM TAP        (closer to TDI)

    // Select CoreSight DAP
    JTAG_DRPre  = 0;  // Sets the number of devices which are closer to TDO than the one we want to communicate with.
    JTAG_DRPost = 1;  // Sets the number of devices which are closer to TDI than the one we want to communicate with.
    JTAG_IRPre  = 0;  // Sets the number of IR-bits of all devices which are closer to TDO than the one we want to communicate with.
    JTAG_IRPost = 8;  // Sets the number of IR-bits of all devices which are closer to TDI than the one we want to communicate with.
    JTAG_IRLen  = 4;  // IRLen of device we want to communicate with
  }
  else {
    Report("Manually configuring JTAG chain for Single Chain");
    JTAG_SetDeviceId(0, Q8_TAP3_ID);       // IRLen: 5 => Q8_TAP3  (closer to TDO)
    JTAG_SetDeviceId(1, Q8_TAP2_ID);       // IRLen: 5 => Q8_TAP2
    JTAG_SetDeviceId(2, Q8_TAP1_ID);       // IRLen: 5 => Q8_TAP1
    JTAG_SetDeviceId(3, Q8_TAP0_ID);       // IRLen: 5 => Q8_TAP0
    JTAG_SetDeviceId(4, CoreSight_DAP_ID); // IRLen: 4 => CoreSight DAP
    JTAG_SetDeviceId(5, BRCM_TAP_ID);      // IRLen: 8 => BRCM TAP (closer to TDI)

    // Select CoreSight DAP
    JTAG_DRPre  =  4; // Sets the number of devices which are closer to TDO than the one we want to communicate with.
    JTAG_DRPost =  1; // Sets the number of devices which are closer to TDI than the one we want to communicate with.
    JTAG_IRPre  = 20; // Sets the number of IR-bits of all devices which are closer to TDO than the one we want to communicate with.
    JTAG_IRPost =  8; // Sets the number of IR-bits of all devices which are closer to TDI than the one we want to communicate with.
    JTAG_IRLen  =  4; // IRLen of device we want to communicate with
  }

  // Global DLL Var CPU: Used in InitTarget() to skip the core auto-detection of J-Link
  if (MCU_ID == 0x00) {
    CPU = CORTEX_M7;
  }
  else if (MCU_ID == 0x01) {
    CPU = CORTEX_M7;
  }
  else if (MCU_ID >= 0x10) {
    CPU = CORTEX_A55;
  }

  
  // Global DLL Var JTAG_AllowTAPReset: 
  //   En-/Disables auto-JTAG-detection of J-Link. Has to be disabled for devices which need some special init (for example to add the core to the JTAG chain), which is lost at a TAP reset.
  JTAG_AllowTAPReset=0; 
  
  // Read JTAG-DP IDCODE
  JTAG_StoreIR(0xE); //Read JTAG-DP IDCODE register
  v = 0;
  BitPos = JTAG_StoreDR(v, 32); //Get IDCODE
  v = JTAG_GetU32(BitPos);
  Report1("CoreSight_DAP IDCODE:", v);
  if (v != CoreSight_DAP_ID) {
    MessageBox("Unexpected CoreSight_DAP IDCODE");
    return 1;
  }

  if (POWERUP_DAP) {
    //
    // Power-up complete DAP
    //
    v = 0
    | (1 << 30) // System power-up
    | (1 << 28) // Debug popwer-up
    | (1 << 5)  // Clear STICKYERR
    ;
    JLINK_CORESIGHT_WriteDAP(JLINK_CORESIGHT_DP_REG_CTRL_STAT, 0, v);
    JLINK_CORESIGHT_WriteDAP(JLINK_CORESIGHT_DP_REG_SELECT, 0, (0 << 24) | (0 << 4)); // Select AP[0], bank 0
    
    Ctrl = 0
    | (2 << 0) // AP-access size. Fixed to 2: 32-bit
    | (1 << 4) // Auto increment TAR after read/write access.
    // After a successful Data Read/Write Register access, the address in the TAR is incremented by the size of the access.
    | (1 << 31) // Enable software access to the Debug APB bus.
    ;
    JLINK_CORESIGHT_WriteDAP(JLINK_CORESIGHT_AP_REG_CTRL, 1, Ctrl);
  } // if (POWERUP_DAP)

  //
  // Select MCU AP
  //
  JLINK_CORESIGHT_AddAP(0, CORESIGHT_AHB_AP);
  JLINK_CORESIGHT_AddAP(1, CORESIGHT_AHB_AP);
  JLINK_CORESIGHT_AddAP(2, CORESIGHT_APB_AP);

  if (MCU_ID == 0x00) {
    CORESIGHT_CoreBaseAddr = CM7_MCU_0_ADDR;
    JLINK_CORESIGHT_IndexAHBAPToUse = 0;
  }
  else if (MCU_ID == 0x01) {
    CORESIGHT_CoreBaseAddr = CM7_MCU_U_ADDR;
    JLINK_CORESIGHT_IndexAHBAPToUse = 1;
  }
  else if (MCU_ID == 0x10) {
    CORESIGHT_CoreBaseAddr = A55_CORE0_ADDR;
    JLINK_ExecCommand(_sExecCTI_CORE0_BaseAddr);
    JLINK_CORESIGHT_IndexAPBAPToUse = 2;
    A55_DBG_REG_BASE_ADDR  = A55_CORE0_ADDR;
  }
  else if (MCU_ID == 0x11) {
    CORESIGHT_CoreBaseAddr = A55_CORE1_ADDR;
    JLINK_ExecCommand(_sExecCTI_CORE1_BaseAddr);
    JLINK_CORESIGHT_IndexAPBAPToUse = 2;
    A55_DBG_REG_BASE_ADDR  = A55_CORE1_ADDR;
  }
  else if (MCU_ID == 0x12) {
    CORESIGHT_CoreBaseAddr = A55_CORE2_ADDR;
    JLINK_ExecCommand(_sExecCTI_CORE2_BaseAddr);
    JLINK_CORESIGHT_IndexAPBAPToUse = 2;
    A55_DBG_REG_BASE_ADDR  = A55_CORE2_ADDR;
  }
  else if (MCU_ID == 0x13) {
    CORESIGHT_CoreBaseAddr = A55_CORE3_ADDR;
    JLINK_ExecCommand(_sExecCTI_CORE3_BaseAddr);
    JLINK_CORESIGHT_IndexAPBAPToUse = 2;
    A55_DBG_REG_BASE_ADDR  = A55_CORE3_ADDR;
  }

}

/*********************************************************************
*
*     BringUp_MCU1
*
*     Function description
*     Reset MCU1, load FreeRTOS binary, set INITVTOR, release reset
*
**********************************************************************/
static void BringUp_MCU1(U32 load_addr) {
  int r;

  Report("=== MCU1 Bring-Up Sequence Start ===");

  // 1. Point CoreSight to MCU1
  CORESIGHT_CoreBaseAddr = CM7_MCU_U_ADDR;        // Debug base for MCU1
  JLINK_CORESIGHT_IndexAHBAPToUse = 1;            // Use AP[1] for MCU1

  // 2. Reset + halt MCU1
  r = _M7_Reset();
  if (r < 0) {
    Report("MCU1 reset failed!");
    return;
  }

  // 4. Update INITVTOR to point to vector table
  JLINK_MEM_WriteU32(MCU_U_INITVTOR_Adr, load_addr);
  // U32 vtor;
  // vtor = JLINK_MEM_ReadU32(MCU_U_INITVTOR_Adr);
  Report1("MCU1 INITVTOR set to ", JLINK_MEM_ReadU32(MCU_U_INITVTOR_Adr));

  // 5. Release reset and enable MCU1
  _Enable_MCU_Utility(1);

  Report("=== MCU1 FreeRTOS bring-up complete ===");
}

static void _Enable_Q8(int core_id) {
  U32 reg;
  reg = RIG_CLKNRST_q8_top_reset_control_Adr;

  // U32 val;

  // 1. Release HRESET (global bus)
  JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_HRESETN_FRC_MASK);
  JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_HRESETN_FRCVAL_MASK);
  JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_HRESETN_FRCVAL_MASK);

  // 2–4. Release PRESET, CRESETB, APB slave reset for the selected core
  if (core_id == 0) {
    // PRESET0
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_0_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_0_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_0_FRCVAL_MASK);

    // CRESETB0
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_0_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_0_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_0_FRCVAL_MASK);

    // APB slave0
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_0_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_0_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_0_FRCVAL_MASK);

  } else if (core_id == 1) {
    // PRESET1
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_1_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_1_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_1_FRCVAL_MASK);

    // CRESETB1
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_1_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_1_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_1_FRCVAL_MASK);

    // APB slave1
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_1_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_1_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_1_FRCVAL_MASK);

  } else if (core_id == 2) {
    // PRESET2
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_2_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_2_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_2_FRCVAL_MASK);

    // CRESETB2
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_2_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_2_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_2_FRCVAL_MASK);

    // APB slave2
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_2_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_2_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_2_FRCVAL_MASK);

  } else if (core_id == 3) {
    // PRESET3
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_3_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_3_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_PRESETN_3_FRCVAL_MASK);

    // CRESETB3
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_3_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_3_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_CRSTB_3_FRCVAL_MASK);

    // APB slave3
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_3_FRC_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) & ~CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_3_FRCVAL_MASK);
    JLINK_MEM_WriteU32(reg, JLINK_MEM_ReadU32(reg) | CLKRST_Q8_TOP_RESET_CONTROL_APBSLAVE_RSTB_3_FRCVAL_MASK);

  } else {
    Report("Invalid Q8 core_id!");
  }
}

/*********************************************************************
*
*     BringUp_Q8
*
*     Function description
*     Reset Q8 DSP core, load binary into SRAM, set vector base, release reset
*
**********************************************************************/
static void BringUp_Q8(int core_id) {
  // Each DSP core starts at its SRAM base
  U32 load_addr;
  load_addr = 0x00100000 + (core_id * 0x10000);

  Report("=== Q8 DSP Bring-Up Sequence Start ===");

  // Release reset
  _Enable_Q8(core_id);

  Report("=== Q8 DSP bring-up complete ===");
}

/*********************************************************************
*
*       SetupTarget
*/
int SetupTarget(void) {

  if (MCU_ID == 0x00) {
    _Read_M7_MCU_ID(0);

    if (RESET_AND_HALT) {
      Report("Chip Reset and Halt...");
      _M7_Reset();
      _DisableWDT();
    }
    if (ENABLE_MCU_UTILITY) {
      _Enable_MCU_Utility(1);
    }

    // Bring up MCU1 FreeRTOS
    BringUp_MCU1(0x01000000);
    
    // Bring up Q8 DSP Core0 (extend to loop if needed)
    BringUp_Q8(0);
  }
  else if (MCU_ID == 0x01) {
    _Read_M7_MCU_ID(1);

    if (RESET_AND_HALT) {
      Report("MCU Utility Reset and Halt...");
      _M7_Reset();
    }
  }
  else if (MCU_ID >= 0x10) {
    _Read_A55_CORE_ID(MCU_ID-0x10);

    if (RESET_AND_HALT) {
      Report("A55 Reset and Halt...");
      _A55_Reset();
    }
  }

  return(0);
}

/*********************************************************************
*
*       ResetTarget
*/
int ResetTarget(void) {

  if (MCU_ID < 0x10) {
    _M7_Reset();
  }
  else {
    _A55_Reset();
  }

  return(0);
}


/*********************************************************************
*
*       AfterResetTarget
*/
int AfterResetTarget(void) {

  if (MCU_ID == 0x00) {
    _DisableWDT();

    if (ENABLE_MCU_UTILITY) {
      _Enable_MCU_Utility(1);
    }
  }

  return(0);
}
